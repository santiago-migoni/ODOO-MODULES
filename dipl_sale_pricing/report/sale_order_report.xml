<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Heredar reporte de presupuesto para agregar Desarrollo y Largo -->
    <template id="report_saleorder_document_inherit_pricing" inherit_id="sale.report_saleorder_document">

        <!-- Agregar columnas en el header de la tabla -->
        <xpath expr="//th[@name='th_quantity']" position="after">
            <th name="th_desarrollo" class="text-end text-nowrap">Desarrollo (mm)</th>
            <th name="th_largo" class="text-end text-nowrap">Largo (mm)</th>
        </xpath>

        <!-- Agregar datos en las filas de producto -->
        <xpath expr="//tr[@name='tr_product']//td[@name='td_product_quantity']" position="after">
            <td name="td_desarrollo" class="text-end text-nowrap">
                <span t-if="line.desarrollo_mm" t-field="line.desarrollo_mm">0.00</span>
                <span t-else="">-</span>
            </td>
            <td name="td_largo" class="text-end text-nowrap">
                <span t-if="line.largo_mm" t-field="line.largo_mm">0.00</span>
                <span t-else="">-</span>
            </td>
        </xpath>

        <!-- Agregar celdas vacías para secciones (para mantener el colspan correcto) -->
        <xpath expr="//tr[@name='tr_section']//td[@name='td_section_name']" position="attributes">
            <attribute name="t-att-colspan">section_name_colspan + 2</attribute>
        </xpath>

        <!-- Agregar celdas vacías para notas -->
        <xpath expr="//tr[@name='tr_note']//td[@name='td_note_name']" position="attributes">
            <attribute name="colspan">99</attribute>
        </xpath>

        <!-- Agregar celdas vacías para combos -->
        <xpath expr="//tr[@name='tr_combo']//td[@name='td_combo_name']" position="attributes">
            <attribute name="t-att-colspan">5 + (1 if display_discount else 0) + (1 if display_taxes else 0)</attribute>
        </xpath>

    </template>
</odoo>
