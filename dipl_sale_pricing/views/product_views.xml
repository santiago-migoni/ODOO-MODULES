<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Heredar vista de formulario de producto -->
    <record id="product_template_form_view_pricing" model="ir.ui.view">
        <field name="name">product.template.form.pricing</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='type']" position="after">
                <field name="es_producto_personalizado" help="Active esta opción si el precio del producto se calcula dinámicamente basado en peso y dimensiones. Los precios se calcularán automáticamente en las órdenes de venta."/>
            </xpath>

            <!-- Hacer precio de venta readonly si es producto personalizado -->
            <xpath expr="//field[@name='list_price']" position="attributes">
                <attribute name="readonly">es_producto_personalizado</attribute>
            </xpath>

            <!-- Agregar página de Cotización por Peso (visible solo si es personalizado) -->
            <xpath expr="//page[@name='sales']" position="after">
                <page string="Cotización por Peso" name="pricing_weight" invisible="not es_producto_personalizado">
                    <group>
                        <group string="Tipo de Cálculo">
                            <field name="tipo_calculo" required="es_producto_personalizado"/>
                        </group>
                    </group>
                    <group>
                        <group string="Precios">
                            <field name="precio_kg" required="es_producto_personalizado"/>
                            <field name="precio_minuto" invisible="tipo_calculo != 'kg_mas_minutos'" required="tipo_calculo == 'kg_mas_minutos'"/>
                        </group>
                        <group string="Propiedades del Material">
                            <field name="material_preset_id" invisible="not es_producto_personalizado"/>
                            <field name="densidad_material"/>
                            <field name="espesor_mm"/>
                        </group>
                    </group>
                    <group string="Dimensiones Máximas" invisible="not es_producto_personalizado">
                        <group>
                            <field name="max_desarrollo_mm"/>
                        </group>
                        <group>
                            <field name="max_largo_mm"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
