<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de lista de materiales predefinidos -->
    <record id="material_preset_tree_view" model="ir.ui.view">
        <field name="name">dipl_sale.material.preset.tree</field>
        <field name="model">dipl_sale.material.preset</field>
        <field name="arch" type="xml">
            <list string="Materiales Predefinidos" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="density"/>
                <field name="description"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Vista de formulario de materiales predefinidos -->
    <record id="material_preset_form_view" model="ir.ui.view">
        <field name="name">dipl_sale.material.preset.form</field>
        <field name="model">dipl_sale.material.preset</field>
        <field name="arch" type="xml">
            <form string="Material Predefinido">
                <sheet>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="density"/>
                        </group>
                        <group>
                            <field name="active"/>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Acción para materiales predefinidos -->
    <record id="material_preset_action" model="ir.actions.act_window">
        <field name="name">Materiales Predefinidos</field>
        <field name="res_model">dipl_sale.material.preset</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crear nuevo material predefinido
            </p>
            <p>
                Configure densidades de materiales comunes para facilitar
                la creación de productos personalizados.
            </p>
        </field>
    </record>

    <!-- Menú en Configuración > Productos -->
    <menuitem id="menu_material_preset" name="Materiales Predefinidos" parent="sale.product_menu_catalog" action="material_preset_action" sequence="99" groups="sales_team.group_sale_manager"/>
</odoo>
