<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.dipl_sale</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Agregar al final de la app de Sales -->
            <xpath expr="//app[@name='sale_management']" position="inside">
                <block title="Cotización por Peso y Minutos" id="dipl_sale_weight_pricing">
                    <setting id="dipl_rounding_unit" string="Unidad de Redondeo" help="Unidad a la que se redondearán los precios calculados">
                        <field name="rounding_unit" widget="radio"/>
                    </setting>
                    <setting id="dipl_material_presets" string="Usar Densidades Predefinidas" help="Ofrecer selección rápida de materiales comunes en productos">
                        <field name="use_material_presets"/>
                    </setting>
                    <setting id="dipl_dimension_validation" string="Validar Dimensiones Máximas" help="Validar que las dimensiones no excedan los límites configurados">
                        <field name="enable_dimension_validation"/>
                        <div class="content-group mt16" invisible="not enable_dimension_validation">
                            <div class="row">
                                <label for="max_desarrollo_global" string="Desarrollo Máximo (mm)" class="col-lg-3 o_light_label"/>
                                <field name="max_desarrollo_global" class="col-lg-9"/>
                            </div>
                            <div class="row mt8">
                                <label for="max_largo_global" string="Largo Máximo (mm)" class="col-lg-3 o_light_label"/>
                                <field name="max_largo_global" class="col-lg-9"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
