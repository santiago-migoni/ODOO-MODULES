<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Materiales predefinidos más comunes -->
        <record id="material_acero" model="dipl_sale.material.preset">
            <field name="sequence">10</field>
            <field name="name">Acero</field>
            <field name="density">7.85</field>
            <field name="description">Acero común, el material más utilizado</field>
        </record>

        <record id="material_acero_inoxidable" model="dipl_sale.material.preset">
            <field name="sequence">20</field>
            <field name="name">Acero Inoxidable</field>
            <field name="density">8.00</field>
            <field name="description">Acero inoxidable 304/316</field>
        </record>

        <record id="material_aluminio" model="dipl_sale.material.preset">
            <field name="sequence">30</field>
            <field name="name">Aluminio</field>
            <field name="density">2.70</field>
            <field name="description">Aluminio puro o aleaciones comunes</field>
        </record>

        <record id="material_cobre" model="dipl_sale.material.preset">
            <field name="sequence">40</field>
            <field name="name">Cobre</field>
            <field name="density">8.96</field>
            <field name="description">Cobre puro</field>
        </record>

        <record id="material_bronce" model="dipl_sale.material.preset">
            <field name="sequence">50</field>
            <field name="name">Bronce</field>
            <field name="density">8.73</field>
            <field name="description">Bronce común (88% Cu, 12% Sn)</field>
        </record>

        <record id="material_laton" model="dipl_sale.material.preset">
            <field name="sequence">60</field>
            <field name="name">Latón</field>
            <field name="density">8.50</field>
            <field name="description">Latón común (70% Cu, 30% Zn)</field>
        </record>

        <record id="material_titanio" model="dipl_sale.material.preset">
            <field name="sequence">70</field>
            <field name="name">Titanio</field>
            <field name="density">4.50</field>
            <field name="description">Titanio comercialmente puro</field>
        </record>

        <record id="material_zinc" model="dipl_sale.material.preset">
            <field name="sequence">80</field>
            <field name="name">Zinc</field>
            <field name="density">7.14</field>
            <field name="description">Zinc puro</field>
        </record>
    </data>
</odoo>
