<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

<t t-name="dipl_web_backend_theme.HomeMenu">
    <div class="dipl_home_menu h-100 overflow-auto">
        <div class="container py-4 py-lg-5">
            <div class="dipl_home_menu_header mb-4 mb-lg-5">
                <button class="btn dipl_home_menu_close" t-on-click="closeHomeMenu" aria-label="Cerrar aplicaciones">
                    <i class="fa fa-times"/>
                </button>
            </div>

            <div t-if="hasResults" class="row g-3 g-lg-4 justify-content-center">
                <div t-foreach="props.apps" t-as="app" t-key="app.id" class="col-6 col-sm-4 col-lg-3 col-xl-2">
                    <button class="dipl_app_card w-100 text-center" t-on-click="() => this.onSelectApp(app)">
                        <div class="dipl_app_card_icon_wrap">
                            <img t-if="app.webIconData" class="dipl_app_card_icon" t-att-src="app.webIconData" t-att-alt="app.label"/>
                            <div t-else="" class="dipl_app_card_fallback_icon">
                                <i class="oi oi-apps"/>
                            </div>
                        </div>
                        <div class="dipl_app_card_body">
                            <div class="dipl_app_card_title" t-esc="app.label"/>
                        </div>
                    </button>
                </div>
            </div>

            <div t-else="" class="dipl_home_menu_empty">
                <div class="dipl_home_menu_empty_card">
                    <h2 class="h4 mb-0">No hay aplicaciones disponibles.</h2>
                </div>
            </div>
        </div>
    </div>
</t>

</templates>
