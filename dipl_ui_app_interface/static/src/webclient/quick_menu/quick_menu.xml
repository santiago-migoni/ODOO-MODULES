<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="dipl_ui_app_interface.QuickMenu">
        <div t-if="isVisible" t-ref="root" class="dipl_quick_menu" t-att-class="{ 'dipl_quick_menu--expanded': state.expanded }" t-on-mouseenter="onMouseEnter" t-on-mouseleave="onMouseLeave">
            <div class="dipl_quick_menu__content">
                <!-- Botón Inicio -->
                <div class="dipl_quick_menu__item dipl_quick_menu__item--home" title="Inicio" t-on-click="navigateToHome">
                    <div class="dipl_quick_menu__icon">
                        <i class="fa fa-home"/>
                    </div>
                    <span class="dipl_quick_menu__name">Inicio</span>
                </div>

                <div class="dipl_quick_menu__separator"/>

                <!-- Lista de Apps -->
                <div class="dipl_quick_menu__app-list">
                    <t t-foreach="allApps" t-as="app" t-key="app.id">
                        <a class="dipl_quick_menu__item" t-att-href="app.href" t-att-title="app.label or app.name" t-on-click.prevent="() => this.onAppClick(app)">
                            <div class="dipl_quick_menu__icon">
                                <img t-if="app.webIconData" t-att-src="app.webIconData" t-att-alt="app.label or app.name" class="dipl_quick_menu__icon-img"/>
                                <div t-else="" class="dipl_quick_menu__icon-fa" t-attf-style="background-color: {{app.webIcon.backgroundColor}};">
                                    <i t-attf-class="{{app.webIcon.iconClass}}" t-attf-style="color: {{app.webIcon.color}};"/>
                                </div>
                            </div>
                            <span class="dipl_quick_menu__name" t-esc="app.label or app.name"/>
                        </a>
                    </t>
                </div>
            </div>
        </div>
    </t>

</templates>
