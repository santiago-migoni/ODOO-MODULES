<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="dipl_ui_app_interface.EnterpriseNavBar" t-inherit="web.NavBar" t-inherit-mode="primary">
        <xpath expr="//nav" position="attributes">
            <attribute name="t-ref">nav</attribute>
        </xpath>
        <xpath expr="//t[@t-call='web.NavBar.AppsMenu']" position="replace">
            <t t-if="!isScopedApp">
                <!-- Hidden element to satisfy navbar.js ref="menuApps" -->
                <div class="d-none" t-ref="menuApps"/>

                <div t-if="!env.isSmall and currentApp" class="d-flex align-items-center h-100">
                    <img t-if="currentApp.webIconData" t-att-src="currentApp.webIconData" class="o_menu_brand_icon d-inline h-100 ps-1 ms-2" style="max-height: 30px; width: auto;" t-att-alt="currentApp.name" t-ref="appIcon"/>
                    <span t-esc="currentApp.name" class="o_menu_brand d-flex ms-3 pe-0 fs-4 text-reset cursor-default"/>
                </div>
            </t>
            <a t-else="" t-att-href="pwa.startUrl" class="o_menu_toggle" t-ref="menuApps">
                <img t-if="currentApp &amp;&amp; currentApp.webIconData" t-att-src="currentApp.webIconData" class="o_menu_brand_icon d-none d-lg-inline position-absolute start-0 h-100 ps-1 ms-2" t-att-alt="currentApp.name" t-ref="appIcon"/>

                <span t-if="currentApp" t-esc="currentApp.name" class="o_menu_brand d-none d-md-flex ps-4 pe-0"/>
            </a>
        </xpath>

        <xpath expr="//DropdownItem[@t-esc='currentApp.name']" position="replace"/>
    </t>

    <t t-name="dipl_ui_app_interface.EnterpriseNavBar.SectionsMenu" t-inherit="web.NavBar.SectionsMenu" t-inherit-mode="extension">
        <xpath expr="//Dropdown/button" position="attributes">
            <attribute name="class" add="fw-normal" separator=" "/>
        </xpath>
    </t>

</templates>
